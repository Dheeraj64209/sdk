# The caller ID must be the number purchased from the Vobiz console.
CALLER_ID=+<your-vobiz-number>

# SIP endpoint URI for inbound calls (from Vobiz Console > Voice > Endpoints)
# Example: sip:user123456789@registrar.vobiz.ai
SIP_ENDPOINT=sip:your-endpoint-username@registrar.vobiz.ai

# Optional: Fallback destination for outbound calls
DEFAULT_DESTINATION=+<your-test-destination>

# Default country code for phone number formatting
DEFAULT_COUNTRY_CODE=91
